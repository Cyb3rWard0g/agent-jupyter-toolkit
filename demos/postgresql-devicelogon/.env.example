# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=devicelogon
POSTGRES_PORT=5432

# Ingestion script settings (host-side, outside Docker)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=devicelogon
PG_SSLMODE=disable

# Kernel-side DSN (used inside the Jupyter container)
# The hostname "postgres" is the Docker Compose service name.
PG_DSN=postgresql://postgres:postgres@postgres:5432/devicelogon?sslmode=disable

# Jupyter
JUPYTER_TOKEN=mcp-dev-token
