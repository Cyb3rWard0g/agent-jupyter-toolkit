# Jupyter container config
JUPYTER_TOKEN=mcp-dev-token

# Optional: PostgreSQL profile config
# Run with: docker compose --profile postgres up -d --build
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=demo
POSTGRES_PORT=5432

# Optional: kernel env var used by postgresql_connect
# Note: when running with Docker Compose, hostname is the service name "postgres".
PG_DSN=postgresql://postgres:postgres@postgres:5432/demo?sslmode=disable
